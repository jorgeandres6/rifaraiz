rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read images (public access)
    match /raffles/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
